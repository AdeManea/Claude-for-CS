{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "ask_user_input_v0",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/run_auq_hook.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "ask_user_input_v0",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/run_auq_hook.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/run_auq_hook.sh"
          }
        ]
      }
    ]
  }
}
